{
  "name": "@spykesocial/react-native-opengraph-scrapper",
  "description": "React Native scraper module for Open Graph and Twitter Card info",
  "version": "1.2.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/write-cjs-wrapper.cjs",
    "eslint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.js\" --fix",
    "eslint": "eslint \"src/**/*.ts\" \"tests/**/*.js\"",
    "mocha:unit": "npm run build && c8 --reporter=html --reporter=text mocha --require ./tests/helpers/bootstrap.js --recursive \"./tests/unit/**/*.spec.js\"",
    "mocha:int": "npm run build && mocha --require ./tests/helpers/bootstrap.js --recursive \"./tests/integration/**/*.spec.js\" --timeout 10000",
    "mocha:rn": "npm run build && mocha --require ./tests/helpers/bootstrap.js --recursive \"./tests/react-native/**/*.spec.js\" --timeout 15000",
    "test": "npm run mocha:unit && npm run mocha:int && npm run mocha:rn"
  },
  "engines": {
    "node": ">=18.x"
  },
  "peerDependencies": {
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "dependencies": {
    "chardet": "^2.1.1",
    "cheerio": "^1.2.0",
    "validator": "^13.15.35"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "devDependencies": {
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "c8": "^11.0.0",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-mocha": "^10.5.0",
    "mocha": "^10.8.2",
    "nyc": "^17.1.0",
    "react": "^19.2.3",
    "react-native": "0.85.3",
    "sinon": "^19.0.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "whatwg-fetch": "^3.6.20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spykesocial/react-native-opengraph-scrapper.git",
    "web": "https://github.com/spykesocial/react-native-opengraph-scrapper"
  },
  "keywords": [
    "app links",
    "dublin core",
    "meta tags",
    "metadata",
    "og",
    "ogp",
    "open graph",
    "opengraph",
    "scraper",
    "twitter card",
    "twitter"
  ]
}
