{
  "extends": [
    "airbnb-base",
    "plugin:mocha/recommended"
  ],
  "plugins": [
    "mocha"
  ],
  "env": {
    "commonjs": true,
    "node": true,
    "mocha": true
  },
  "rules": {
    "max-len": ["error", {
      "code": 120,
      "ignoreStrings": true,
      "ignoreTrailingComments": true
    }],
    "no-param-reassign": "off"
  }
}
